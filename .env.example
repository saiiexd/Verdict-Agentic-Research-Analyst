# ═══════════════════════════════════════════════════════════════════
# Verdict AI — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════
# Copy this file to `backend/.env` (and root `.env` if desired) and 
# fill in your API keys. NEVER commit real secrets to version control.

# ── Required API Keys ───────────────────────────────────────────────

# Tavily Search API key (required for News Agent web scraping)
# Get one at: https://app.tavily.com
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# LLM Configuration (e.g. gemini, openai, openrouter, groq)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-pro
LLM_API_KEY=your-llm-api-key-here

# ── Optional: Application Settings ──────────────────────────────────
APP_NAME="Verdict API"
APP_VERSION="1.0.0"
DEBUG=True

# ── Optional: LangSmith Tracing ─────────────────────────────────────
# Enables observability and trace inspection for the LangGraph workflow.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY="your_langsmith_api_key_here"
# LANGCHAIN_PROJECT="verdict-ai-research-agent"
